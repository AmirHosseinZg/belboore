---
import ToolWorkspace from './ToolWorkspace.astro';
import ToolPrimitives from './ToolPrimitives.astro';
import ToolUtils from './ToolUtils.astro';
---

<ToolWorkspace title="Password Generator">
  <ToolPrimitives />
  <ToolUtils />

  <div class="tool-toolbar">
    <label class="tool-field__label" for="pw-length" style="margin:0;display:flex;align-items:center;gap:var(--space-2)">
      Length
      <input id="pw-length" class="tool-input" type="number" min="6" max="64" value="16" style="width:70px" />
    </label>
    <label class="tool-checkbox">
      <input type="checkbox" id="pw-uppercase" checked /> A-Z
    </label>
    <label class="tool-checkbox">
      <input type="checkbox" id="pw-lowercase" checked /> a-z
    </label>
    <label class="tool-checkbox">
      <input type="checkbox" id="pw-numbers" checked /> 0-9
    </label>
    <label class="tool-checkbox">
      <input type="checkbox" id="pw-symbols" /> !@#$
    </label>
  </div>
  <div class="tool-toolbar">
    <button id="pw-generate" type="button" class="tool-btn tool-btn--primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      Generate
    </button>
    <button id="pw-copy" type="button" class="tool-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      Copy
    </button>
  </div>
  <div id="pw-result-card" class="tool-result" style="display:none;" role="status" aria-live="polite">
    <div id="pw-display" class="tool-result__value"></div>
    <div id="pw-strength" class="tool-result__label"></div>
  </div>
  <div id="pw-empty" class="tool-output tool-output--empty">Click Generate to create a password</div>
  <div class="tool-note">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    Passwords are generated entirely in your browser using <code>crypto.getRandomValues</code>. They are never stored or sent anywhere.
  </div>
</ToolWorkspace>

<script>
  const lengthInput = document.getElementById('pw-length') as HTMLInputElement;
  const uppercaseCb = document.getElementById('pw-uppercase') as HTMLInputElement;
  const lowercaseCb = document.getElementById('pw-lowercase') as HTMLInputElement;
  const numbersCb = document.getElementById('pw-numbers') as HTMLInputElement;
  const symbolsCb = document.getElementById('pw-symbols') as HTMLInputElement;
  const resultCard = document.getElementById('pw-result-card')!;
  const pwDisplay = document.getElementById('pw-display')!;
  const pwStrength = document.getElementById('pw-strength')!;
  const emptyState = document.getElementById('pw-empty')!;

  function clampLength() {
    let len = parseInt(lengthInput.value, 10);
    if (isNaN(len) || len < 6) len = 6;
    if (len > 64) len = 64;
    lengthInput.value = String(len);
    return len;
  }

  lengthInput.addEventListener('blur', function () {
    clampLength();
  });

  function getCharset(): { charset: string; description: string[] } {
    const parts: string[] = [];
    let charset = '';
    if (uppercaseCb.checked) { charset += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'; parts.push('uppercase'); }
    if (lowercaseCb.checked) { charset += 'abcdefghijklmnopqrstuvwxyz'; parts.push('lowercase'); }
    if (numbersCb.checked) { charset += '0123456789'; parts.push('numbers'); }
    if (symbolsCb.checked) { charset += '!@#$%^&*()_+-=[]{}|;:,.<>?'; parts.push('symbols'); }
    return { charset, description: parts };
  }

  function generatePassword(length: number, charset: string): string {
    const array = new Uint32Array(length);
    crypto.getRandomValues(array);
    let result = '';
    for (let i = 0; i < length; i++) {
      result += charset[array[i] % charset.length];
    }
    return result;
  }

  function getStrength(length: number, charset: string): string {
    const pool = new Set(charset).size;
    const entropy = length * Math.log2(pool);
    if (entropy < 40) return 'Weak';
    if (entropy < 60) return 'Fair';
    if (entropy < 80) return 'Good';
    if (entropy < 100) return 'Strong';
    return 'Very Strong';
  }

  document.getElementById('pw-generate')!.addEventListener('click', () => {
    const length = clampLength();
    const { charset, description } = getCharset();

    if (!charset || description.length === 0) {
      window.__belbooreTools.showEmpty(emptyState, 'Select at least one character set');
      resultCard.style.display = 'none';
      emptyState.style.display = '';
      return;
    }

    const password = generatePassword(length, charset);
    const strength = getStrength(length, charset);

    pwDisplay.textContent = password;
    pwStrength.textContent = 'Strength: ' + strength + ' \u2014 ' + description.join(', ');
    emptyState.style.display = 'none';
    resultCard.style.display = '';
  });

  document.getElementById('pw-copy')!.addEventListener('click', () => {
    const text = pwDisplay.textContent || '';
    if (!text) return;
    const btn = document.getElementById('pw-copy')!;
    window.__belbooreTools.copyToClipboard(text, btn, 1500);
  });
</script>
