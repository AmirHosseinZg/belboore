---
// BELBOORE TOOL DESIGN SYSTEM — SHARED UTILITIES
// Used by all tool workspace components
---

<style>
  /* ── Tool Shell ── */
  .tool-shell {
    display: flex;
    flex-direction: column;
  }

  /* ── Tool Panel ── */
  .tool-panel {
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .tool-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
    gap: var(--space-3);
  }

  .tool-panel__title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
  }

  .tool-panel__body {
    padding: var(--space-5);
  }

  /* ── Tool Toolbar ── */
  .tool-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding: var(--space-3) 0;
  }

  .tool-toolbar--sticky {
    position: sticky;
    top: var(--header-height);
    z-index: 10;
    background: var(--surface-primary);
    padding: var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
    margin: calc(-1 * var(--space-5));
    margin-bottom: var(--space-4);
  }

  /* ── Tool Input Base ── */
  .tool-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: inherit;
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--text-primary);
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .tool-input:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .tool-input::placeholder {
    color: var(--text-muted);
  }

  .tool-input--mono {
    font-family: var(--font-mono);
  }

  .tool-input--sm {
    padding: var(--space-2) var(--space-3);
  }

  /* ── Tool Textarea ── */
  .tool-textarea {
    width: 100%;
    min-height: 160px;
    padding: var(--space-4);
    font-family: inherit;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    resize: vertical;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .tool-textarea:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .tool-textarea::placeholder {
    color: var(--text-muted);
  }

  .tool-textarea--mono {
    font-family: var(--font-mono);
  }

  .tool-textarea--resize-none {
    resize: none;
  }

  /* ── Tool Select ── */
  .tool-select {
    padding: var(--space-2) var(--space-4);
    font-family: inherit;
    font-size: var(--text-sm);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--surface-primary);
    color: var(--text-primary);
    cursor: pointer;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .tool-select:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  /* ── Tool Button ── */
  .tool-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
    background: var(--surface-primary);
    color: var(--text-secondary);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .tool-btn:hover {
    background: var(--surface-tertiary);
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  .tool-btn--primary {
    background: var(--color-tech-blue);
    color: white;
    border-color: var(--color-tech-blue);
    box-shadow: 0 1px 3px rgba(0, 82, 255, 0.2);
  }

  .tool-btn--primary:hover {
    background: var(--color-tech-blue-hover);
    color: white;
    border-color: var(--color-tech-blue-hover);
    box-shadow: 0 2px 6px rgba(0, 82, 255, 0.3);
  }

  .tool-btn--ghost {
    background: transparent;
    border-color: transparent;
    color: var(--text-tertiary);
  }

  .tool-btn--ghost:hover {
    background: var(--surface-tertiary);
    color: var(--text-primary);
    border-color: transparent;
  }

  .tool-btn--danger {
    background: var(--color-error-subtle);
    color: var(--color-error);
    border-color: var(--color-error-border);
  }

  .tool-btn--danger:hover {
    background: var(--color-error);
    color: white;
    border-color: var(--color-error);
  }

  .tool-btn--copied {
    background: var(--color-success) !important;
    border-color: var(--color-success) !important;
    color: white !important;
  }

  .tool-btn:disabled,
  .tool-btn--disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .tool-btn--sm {
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
  }

  /* ── Tool Output ── */
  .tool-output {
    width: 100%;
    min-height: 120px;
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--surface-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    white-space: pre-wrap;
    word-break: break-all;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
  }

  .tool-output--empty {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    font-style: italic;
  }

  .tool-output--error {
    border-color: var(--color-error-border);
    background: var(--color-error-subtle);
    color: var(--color-error);
    font-style: normal;
  }

  /* ── Tool Result ── */
  .tool-result {
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    text-align: center;
  }

  .tool-result__value {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    word-break: break-all;
    line-height: 1.4;
  }

  .tool-result__label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
  }

  /* ── Tool Error ── */
  .tool-error {
    padding: var(--space-3) var(--space-4);
    background: var(--color-error-subtle);
    border: 1px solid var(--color-error-border);
    border-radius: var(--radius-md);
    color: var(--color-error);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  /* ── Tool Empty State ── */
  .tool-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: var(--space-8);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .tool-empty__icon {
    font-size: 2rem;
    margin-bottom: var(--space-3);
    opacity: 0.5;
  }

  /* ── Tool Success ── */
  .tool-success {
    padding: var(--space-3) var(--space-4);
    background: var(--color-success-subtle);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-md);
    color: var(--color-success);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ── Tool Note / Info Box ── */
  .tool-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .tool-note__icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Tool Field Group ── */
  .tool-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .tool-field__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }

  .tool-field__hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* ── Tool Row / Grid ── */
  .tool-row {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .tool-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .tool-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 640px) {
    .tool-grid-2,
    .tool-row {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .tool-grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Tool Checkbox ── */
  .tool-checkbox {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    cursor: pointer;
  }

  .tool-checkbox input {
    accent-color: var(--color-tech-blue);
    width: 16px;
    height: 16px;
  }

  /* ── Spinner ── */
  .tool-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--border-subtle);
    border-top-color: var(--color-tech-blue);
    border-radius: 50%;
    animation: tool-spin 0.6s linear infinite;
  }

  @keyframes tool-spin {
    to { transform: rotate(360deg); }
  }

  /* ── Screen Reader Only ── */
  .tool-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
