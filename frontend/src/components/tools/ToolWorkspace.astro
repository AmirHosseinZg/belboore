---
const { title, description } = Astro.props as { title?: string; description?: string };
---
<div class="workspace surface-card">
  {title && <div class="workspace__header">
    <h3 class="workspace__title">{title}</h3>
    {description && <p class="workspace__desc">{description}</p>}
  </div>}
  <div class="workspace__body">
    <slot />
  </div>
</div>

<style>
  .workspace {
    overflow: hidden;
  }

  .workspace__header {
    padding: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
  }

  .workspace__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-1);
  }

  .workspace__desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: 0;
  }

  .workspace__body {
    padding: var(--space-6);
  }

  .workspace__controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .workspace__textarea {
    width: 100%;
    min-height: 180px;
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    resize: vertical;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .workspace__textarea:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .workspace__output {
    width: 100%;
    min-height: 120px;
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--surface-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    white-space: pre-wrap;
    word-break: break-all;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
  }

  .workspace__output--empty {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    font-style: italic;
  }

  .workspace__input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .workspace__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }

  .workspace__actions {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    margin-top: var(--space-4);
  }

  .workspace__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
    background: var(--surface-primary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .workspace__btn:hover {
    background: var(--surface-tertiary);
    color: var(--text-primary);
  }

  .workspace__btn--primary {
    background: var(--color-tech-blue);
    color: white;
    border-color: var(--color-tech-blue);
  }

  .workspace__btn--primary:hover {
    background: var(--color-tech-blue-hover);
    color: white;
  }

  .workspace__btn--copied {
    background: var(--color-success) !important;
    border-color: var(--color-success) !important;
    color: white !important;
  }

  .workspace__btn--ghost {
    background: transparent;
    border-color: transparent;
    color: var(--text-tertiary);
  }

  .workspace__btn--ghost:hover {
    background: var(--surface-tertiary);
    color: var(--text-primary);
  }

  .workspace__btn--danger {
    background: var(--color-error-subtle);
    color: var(--color-error);
    border-color: var(--color-error-border);
  }

  .workspace__btn--danger:hover {
    background: var(--color-error);
    color: white;
    border-color: var(--color-error);
  }

  .workspace__btn:disabled,
  .workspace__btn--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .workspace__checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    cursor: pointer;
  }

  .workspace__checkbox-label input {
    accent-color: var(--color-tech-blue);
  }

  .workspace__select {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-family: inherit;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--surface-primary);
    color: var(--text-primary);
    cursor: pointer;
    outline: none;
  }

  .workspace__select:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .workspace__select:focus-visible {
    outline: 2px solid var(--color-tech-blue);
    outline-offset: 2px;
  }

  .workspace__input {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--surface-primary);
    color: var(--text-primary);
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .workspace__input:focus {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .workspace__error {
    padding: var(--space-3) var(--space-4);
    background: var(--color-error-subtle);
    border: 1px solid var(--color-error-border);
    border-radius: var(--radius-md);
    color: var(--color-error);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
  }

  .workspace__output--error {
    border-color: var(--color-error-border);
    color: var(--color-error);
  }

  .workspace__spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--border-subtle);
    border-top-color: var(--color-tech-blue);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .workspace__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .workspace__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }

  .workspace__note {
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .workspace__result-card {
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    text-align: center;
  }

  .workspace__result-value {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    word-break: break-all;
  }

  .workspace__result-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
  }

  .workspace__grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .workspace__grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
