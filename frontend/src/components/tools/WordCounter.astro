---
import type { Lang } from '../../i18n/utils';
import { languages } from '../../i18n/utils';
import ToolWorkspace from './ToolWorkspace.astro';
import ToolPrimitives from './ToolPrimitives.astro';
import ToolUtils from './ToolUtils.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const dir = languages[lang].dir;

const copy = {
  en: {
    title: 'Word & Character Counter',
    label: 'Text to analyze',
    placeholder: 'Paste or write your text here. Statistics update as you type...',
    clear: 'Clear text',
    words: 'Words',
    charsNoSpaces: 'Characters without spaces',
    charsWithSpaces: 'Characters with spaces',
    sentences: 'Sentences',
    paragraphs: 'Paragraphs',
    readingTime: 'Reading time',
    emptyTitle: 'Start typing to analyze your text',
    emptyDesc: 'Word count, characters, sentences, paragraphs, and reading time will appear here.',
    note: 'All processing happens in your browser. Your data is never uploaded.',
    live: 'Live analysis',
    avgWord: 'Avg. word length',
    minutesSuffix: 'min',
    charsSuffix: 'chars',
  },
  fa: {
    title: 'شمارنده کلمات و کاراکترها',
    label: 'متن برای تحلیل',
    placeholder: 'متن خود را اینجا بنویسید یا جای‌گذاری کنید. آمار همزمان با تایپ به‌روز می‌شود...',
    clear: 'پاک کردن متن',
    words: 'کلمات',
    charsNoSpaces: 'کاراکتر بدون فاصله',
    charsWithSpaces: 'کاراکتر با فاصله',
    sentences: 'جملات',
    paragraphs: 'پاراگراف‌ها',
    readingTime: 'زمان مطالعه',
    emptyTitle: 'برای تحلیل متن شروع به تایپ کنید',
    emptyDesc: 'تعداد کلمات، کاراکترها، جملات، پاراگراف‌ها و زمان مطالعه اینجا نمایش داده می‌شود.',
    note: 'تمام پردازش در مرورگر شما انجام می‌شود و داده‌های شما آپلود نمی‌شود.',
    live: 'تحلیل زنده',
    avgWord: 'میانگین طول کلمه',
    minutesSuffix: 'دقیقه',
    charsSuffix: 'کاراکتر',
  },
}[lang];
---

<ToolWorkspace title={copy.title}>
  <ToolPrimitives />
  <ToolUtils />

  <div class="word-counter" dir={dir}>
    <section class="word-counter__editor" aria-label={copy.label}>
      <div class="word-counter__editor-head">
        <div>
          <p class="word-counter__eyebrow">{copy.live}</p>
          <label class="word-counter__label" for="wc-input">{copy.label}</label>
        </div>
        <button type="button" id="wc-clear" class="word-counter__clear" aria-label={copy.clear} title={copy.clear}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18" />
            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
          </svg>
        </button>
      </div>

      <textarea
        id="wc-input"
        class="word-counter__textarea"
        placeholder={copy.placeholder}
        dir="auto"
      ></textarea>
    </section>

    <section class="word-counter__summary" aria-live="polite">
      <div class="word-counter__summary-card word-counter__summary-card--primary">
        <span class="word-counter__summary-label">{copy.words}</span>
        <strong id="wc-words">0</strong>
      </div>
      <div class="word-counter__summary-card">
        <span class="word-counter__summary-label">{copy.readingTime}</span>
        <strong id="wc-reading">0 {copy.minutesSuffix}</strong>
      </div>
      <div class="word-counter__summary-card">
        <span class="word-counter__summary-label">{copy.avgWord}</span>
        <strong><span id="wc-avg-word">0</span> {copy.charsSuffix}</strong>
      </div>
    </section>

    <div id="wc-empty" class="word-counter__empty">
      <div class="word-counter__empty-icon" aria-hidden="true">¶</div>
      <strong>{copy.emptyTitle}</strong>
      <p>{copy.emptyDesc}</p>
    </div>

    <div id="wc-stats" class="word-counter__stats" aria-live="polite">
      <article class="word-counter__stat">
        <span class="word-counter__stat-icon" aria-hidden="true">Aa</span>
        <div>
          <strong id="wc-chars-ns">0</strong>
          <span>{copy.charsNoSpaces}</span>
        </div>
      </article>
      <article class="word-counter__stat">
        <span class="word-counter__stat-icon" aria-hidden="true">␣</span>
        <div>
          <strong id="wc-chars-ws">0</strong>
          <span>{copy.charsWithSpaces}</span>
        </div>
      </article>
      <article class="word-counter__stat">
        <span class="word-counter__stat-icon" aria-hidden="true">.</span>
        <div>
          <strong id="wc-sentences">0</strong>
          <span>{copy.sentences}</span>
        </div>
      </article>
      <article class="word-counter__stat">
        <span class="word-counter__stat-icon" aria-hidden="true">¶</span>
        <div>
          <strong id="wc-paragraphs">0</strong>
          <span>{copy.paragraphs}</span>
        </div>
      </article>
    </div>

    <div class="tool-note word-counter__note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      {copy.note}
    </div>
  </div>
</ToolWorkspace>

<script>
  const wcRoot = document.querySelector('.word-counter') as HTMLElement | null;
  const wcInput = document.getElementById('wc-input') as HTMLTextAreaElement;
  const wcClear = document.getElementById('wc-clear') as HTMLButtonElement;
  const wcWords = document.getElementById('wc-words')!;
  const wcCharsNS = document.getElementById('wc-chars-ns')!;
  const wcCharsWS = document.getElementById('wc-chars-ws')!;
  const wcSentences = document.getElementById('wc-sentences')!;
  const wcParagraphs = document.getElementById('wc-paragraphs')!;
  const wcReading = document.getElementById('wc-reading')!;
  const wcAvgWord = document.getElementById('wc-avg-word')!;
  const wcEmpty = document.getElementById('wc-empty')!;
  const wcStats = document.getElementById('wc-stats')!;

  const minuteSuffix = wcReading.textContent?.replace(/^0\s*/, '') || 'min';
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;

  function getContentDirection(text: string) {
    const firstStrongChar = text.match(/[\p{Script=Arabic}\p{Script=Hebrew}A-Za-z]/u)?.[0] || '';
    return /[\p{Script=Arabic}\p{Script=Hebrew}]/u.test(firstStrongChar) ? 'rtl' : 'ltr';
  }

  function formatNumber(value: number) {
    return new Intl.NumberFormat(document.documentElement.lang || 'en').format(value);
  }

  function update() {
    const text = wcInput.value;
    const trimmed = text.trim();
    const hasText = Boolean(trimmed);

    wcInput.setAttribute('dir', hasText ? getContentDirection(trimmed) : 'auto');
    wcRoot?.classList.toggle('word-counter--has-text', hasText);
    wcStats.hidden = !hasText;
    wcEmpty.hidden = hasText;

    if (!hasText) {
      wcWords.textContent = '0';
      wcCharsNS.textContent = '0';
      wcCharsWS.textContent = '0';
      wcSentences.textContent = '0';
      wcParagraphs.textContent = '0';
      wcAvgWord.textContent = '0';
      wcReading.textContent = '0 ' + minuteSuffix;
      return;
    }

    const words = trimmed.split(/\s+/).filter(Boolean);
    const wordCount = words.length;
    const charsNoSpaces = text.replace(/\s/g, '').length;
    const charsWithSpaces = text.length;
    const sentences = text.split(/[.!?؟。]+/).filter((s) => s.trim().length > 0);
    const paragraphs = text.split(/\n\s*\n/).filter((p) => p.trim().length > 0);
    const minutes = Math.max(1, Math.ceil(wordCount / 200));
    const avgWordLength = wordCount ? Math.round(charsNoSpaces / wordCount) : 0;

    wcWords.textContent = formatNumber(wordCount);
    wcCharsNS.textContent = formatNumber(charsNoSpaces);
    wcCharsWS.textContent = formatNumber(charsWithSpaces);
    wcSentences.textContent = formatNumber(sentences.length);
    wcParagraphs.textContent = formatNumber(paragraphs.length || 1);
    wcAvgWord.textContent = formatNumber(avgWordLength);
    wcReading.textContent = formatNumber(minutes) + ' ' + minuteSuffix;
  }

  wcInput.addEventListener('input', () => {
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(update, 120);
  });

  wcClear.addEventListener('click', () => {
    wcInput.value = '';
    update();
    wcInput.focus();
  });

  update();
</script>

<style>
  .word-counter {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .word-counter__editor {
    padding: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: calc(var(--radius-lg) + 4px);
    background:
      radial-gradient(circle at top right, rgba(0, 82, 255, 0.08), transparent 34%),
      linear-gradient(180deg, var(--surface-primary), var(--surface-secondary));
    box-shadow: var(--shadow-sm);
  }

  .word-counter__editor-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-2) var(--space-4);
  }

  .word-counter__eyebrow {
    margin: 0 0 var(--space-1);
    color: var(--color-tech-blue);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .word-counter__label {
    color: var(--text-primary);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
  }

  .word-counter__clear {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    color: var(--color-error);
    background: var(--color-error-subtle);
    border: 1px solid var(--color-error-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .word-counter__clear:hover {
    color: white;
    background: var(--color-error);
    transform: translateY(-1px);
  }

  .word-counter__textarea {
    width: 100%;
    min-height: 360px;
    padding: var(--space-6);
    color: var(--text-primary);
    font: inherit;
    font-size: var(--text-base);
    line-height: 1.85;
    background:
      linear-gradient(90deg, rgba(0, 82, 255, 0.035) 0 1px, transparent 1px) 0 0 / 28px 28px,
      linear-gradient(180deg, color-mix(in srgb, var(--surface-primary) 96%, transparent), color-mix(in srgb, var(--surface-secondary) 92%, transparent));
    border: 1px solid rgba(0, 82, 255, 0.14);
    border-radius: var(--radius-lg);
    outline: none;
    resize: vertical;
    unicode-bidi: plaintext;
    caret-color: var(--color-tech-blue);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-elevated) 72%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--surface-elevated) 42%, transparent);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .word-counter__textarea:focus {
    border-color: var(--color-tech-blue);
    box-shadow:
      0 0 0 4px var(--color-tech-blue-subtle),
      0 14px 34px rgba(0, 82, 255, 0.08),
      inset 0 1px 0 color-mix(in srgb, var(--surface-elevated) 72%, transparent);
  }

  .word-counter__textarea::placeholder {
    color: color-mix(in srgb, var(--text-muted) 82%, transparent);
  }

  .word-counter__summary {
    display: grid;
    grid-template-columns: 1.15fr 1fr 1fr;
    gap: var(--space-3);
  }

  .word-counter__summary-card,
  .word-counter__stat {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background: var(--surface-primary);
    box-shadow: var(--shadow-sm);
  }

  .word-counter__summary-card {
    min-height: 96px;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
  }

  .word-counter__summary-card::after,
  .word-counter__stat::after {
    content: '';
    position: absolute;
    inset: auto -24% -62% auto;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(0, 82, 255, 0.08);
    pointer-events: none;
  }

  .word-counter__summary-card--primary {
    color: white;
    background: linear-gradient(135deg, rgba(94, 125, 194, 0.76), rgba(19, 87, 235, 0.76));
    border-color: transparent;
  }

  .word-counter__summary-label {
    display: block;
    margin-bottom: var(--space-2);
    color: currentColor;
    opacity: 0.76;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.01em;
  }

  .word-counter__summary-card strong {
    position: relative;
    z-index: 1;
    color: currentColor;
    font-family: var(--font-mono);
    font-size: clamp(1.55rem, 3vw, 1.8rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .word-counter__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .word-counter__stats[hidden],
  .word-counter__empty[hidden] {
    display: none;
  }

  .word-counter__stat {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-height: 86px;
    padding: var(--space-3);
    border-radius: var(--radius-lg);
  }

  .word-counter__stat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    color: var(--color-tech-blue);
    font-family: var(--font-mono);
    font-weight: var(--weight-bold);
    background: var(--color-tech-blue-subtle);
    border-radius: var(--radius-md);
  }

  .word-counter__stat strong {
    display: block;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .word-counter__stat span:last-child {
    display: block;
    margin-top: var(--space-2);
    color: var(--text-muted);
    font-size: 0.7rem;
    font-weight: var(--weight-semibold);
    line-height: 1.25;
  }

  .word-counter__empty {
    display: grid;
    place-items: center;
    gap: var(--space-2);
    min-height: 180px;
    padding: var(--space-8);
    color: var(--text-muted);
    text-align: center;
    background:
      radial-gradient(circle at center, rgba(0, 82, 255, 0.08), transparent 42%),
      var(--surface-primary);
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-xl);
  }

  .word-counter__empty-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    color: var(--color-tech-blue);
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    background: var(--color-tech-blue-subtle);
    border-radius: var(--radius-lg);
  }

  .word-counter__empty strong {
    color: var(--text-primary);
    font-size: var(--text-lg);
  }

  .word-counter__empty p {
    max-width: 420px;
    margin: 0;
    color: var(--text-tertiary);
    line-height: 1.7;
  }

  .word-counter__note {
    margin-top: 0;
  }

  [data-theme="dark"] .word-counter__editor {
    background:
      radial-gradient(circle at top right, rgba(61, 139, 255, 0.12), transparent 34%),
      linear-gradient(180deg, var(--surface-elevated), var(--surface-secondary));
    border-color: var(--border-default);
  }

  [data-theme="dark"] .word-counter__textarea {
    background:
      linear-gradient(90deg, rgba(61, 139, 255, 0.055) 0 1px, transparent 1px) 0 0 / 28px 28px,
      linear-gradient(180deg, var(--surface-elevated), var(--surface-tertiary));
    border-color: rgba(61, 139, 255, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 0 0 1px rgba(255, 255, 255, 0.025);
  }

  [data-theme="dark"] .word-counter__summary-card,
  [data-theme="dark"] .word-counter__stat,
  [data-theme="dark"] .word-counter__empty {
    background-color: var(--surface-elevated);
    border-color: var(--border-default);
  }

  @media (max-width: 900px) {
    .word-counter__summary,
    .word-counter__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .word-counter__editor {
      padding: var(--space-2);
    }

    .word-counter__editor-head {
      padding-inline: var(--space-1);
    }

    .word-counter__textarea {
      min-height: 300px;
      padding: var(--space-4);
    }

    .word-counter__summary,
    .word-counter__stats {
      grid-template-columns: 1fr;
    }
  }
</style>
