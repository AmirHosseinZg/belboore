---
interface Props {
  id: string;
  label: string;
  hint?: string;
  placeholder?: string;
  type?: string;
  inputmode?: string;
  autocomplete?: string;
}

const {
  id,
  label,
  hint,
  placeholder = '',
  type = 'text',
  inputmode = 'text',
  autocomplete = 'off',
} = Astro.props;

const hintId = hint ? `${id}-hint` : undefined;
---

<div class="tool-input-shell">
  <label class="tool-input-shell__label" id={`${id}-label`} for={id}>{label}</label>
  <input
    id={id}
    class="tool-input-shell__control"
    type={type}
    inputmode={inputmode}
    autocomplete={autocomplete}
    placeholder={placeholder}
    aria-describedby={hintId}
  />
  {hint && <p id={hintId} class="tool-input-shell__hint">{hint}</p>}
</div>

<style>
  .tool-input-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border: 1px solid transparent;
    border-radius: calc(var(--radius-lg) - 4px);
    background: var(--surface-tertiary);
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .tool-input-shell:focus-within {
    border-color: var(--color-tech-blue);
    box-shadow: 0 0 0 3px var(--color-tech-blue-subtle);
  }

  .tool-input-shell__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
  }

  .tool-input-shell__control {
    width: 100%;
    padding: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--text-primary);
    font: inherit;
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .tool-input-shell__control::placeholder {
    color: var(--text-muted);
  }

  .tool-input-shell__hint {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
  }
</style>
