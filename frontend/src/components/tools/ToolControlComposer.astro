    padding: var(--space-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(236, 244, 255, 0.66)),
      var(--surface-primary);
