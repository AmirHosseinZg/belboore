---
import ToolWorkspace from './ToolWorkspace.astro';
import ToolPrimitives from './ToolPrimitives.astro';
import ToolUtils from './ToolUtils.astro';
---

<ToolWorkspace title="Base64 Encoder / Decoder">
  <ToolPrimitives />
  <ToolUtils />
  <div class="tool-toolbar">
    <button type="button" id="b64-encode" class="tool-btn tool-btn--primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 8 16 13"/><line x1="21" y1="8" x2="9" y2="8"/><polyline points="5 8 5 3 20 3"/><polyline points="9 13 9 21 5 21 5 16"/><line x1="18" y1="21" x2="21" y2="16"/></svg>
      Encode
    </button>
    <button type="button" id="b64-decode" class="tool-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 3 3 8 8 13"/><line x1="3" y1="8" x2="15" y2="8"/><polyline points="19 8 19 3 4 3"/><polyline points="15 13 15 21 19 21 19 16"/><line x1="6" y1="21" x2="3" y2="16"/></svg>
      Decode
    </button>
    <button type="button" id="b64-copy" class="tool-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      Copy
    </button>
    <button type="button" id="b64-clear" class="tool-btn" aria-label="Clear">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      Clear
    </button>
    <button type="button" id="b64-swap" class="tool-btn" aria-label="Swap input and output">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
      Swap
    </button>
  </div>
  <div id="b64-error" class="tool-error" style="display: none;" role="alert"></div>
  <div class="tool-grid-2">
    <div class="tool-field">
      <label class="tool-field__label" for="b64-input">Input</label>
      <textarea id="b64-input" class="tool-textarea" placeholder="Enter text to encode or Base64 to decode..."></textarea>
    </div>
    <div class="tool-field">
      <label class="tool-field__label" for="b64-output">Output</label>
      <div id="b64-output" class="tool-output tool-output--empty" role="status" aria-live="polite">Encoded / decoded result will appear here</div>
    </div>
  </div>
  <div class="tool-note">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    All processing happens in your browser. Your data is never uploaded.
  </div>
</ToolWorkspace>

<script>
  const input = document.getElementById('b64-input') as HTMLTextAreaElement;
  const output = document.getElementById('b64-output')!;
  const errorDiv = document.getElementById('b64-error')!;

  function utf8ToBase64(str: string): string {
    const bytes = new TextEncoder().encode(str);
    let binary = '';
    for (let i = 0; i < bytes.length; i++) {
      binary += String.fromCharCode(bytes[i]);
    }
    return btoa(binary);
  }

  function base64ToUtf8(b64: string): string {
    const binary = atob(b64);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) {
      bytes[i] = binary.charCodeAt(i);
    }
    return new TextDecoder().decode(bytes);
  }

  document.getElementById('b64-encode')!.addEventListener('click', () => {
    const val = input.value;
    if (!val) { window.__belbooreTools.showEmpty(output, 'Encoded / decoded result will appear here'); window.__belbooreTools.clearErrorBox(errorDiv); return; }
    try {
      window.__belbooreTools.showOutput(output, utf8ToBase64(val));
      window.__belbooreTools.clearErrorBox(errorDiv);
    } catch (e: any) {
      window.__belbooreTools.setErrorBox(errorDiv, e.message || 'Encoding failed');
    }
  });

  document.getElementById('b64-decode')!.addEventListener('click', () => {
    const val = input.value.trim();
    if (!val) { window.__belbooreTools.showEmpty(output, 'Encoded / decoded result will appear here'); window.__belbooreTools.clearErrorBox(errorDiv); return; }
    try {
      window.__belbooreTools.showOutput(output, base64ToUtf8(val));
      window.__belbooreTools.clearErrorBox(errorDiv);
    } catch (e: any) {
      window.__belbooreTools.setErrorBox(errorDiv, 'Invalid Base64 string — could not decode');
      window.__belbooreTools.showEmpty(output, 'Fix the error above and try again');
    }
  });

  document.getElementById('b64-copy')!.addEventListener('click', async () => {
    const text = output.textContent || '';
    if (!text || output.classList.contains('tool-output--empty')) return;
    window.__belbooreTools.copyToClipboard(text, document.getElementById('b64-copy')!, 1500);
  });

  document.getElementById('b64-clear')!.addEventListener('click', () => {
    input.value = '';
    window.__belbooreTools.showEmpty(output, 'Encoded / decoded result will appear here');
    window.__belbooreTools.clearErrorBox(errorDiv);
  });

  document.getElementById('b64-swap')!.addEventListener('click', () => {
    const currentOutput = output.textContent || '';
    if (!output.classList.contains('tool-output--empty') && currentOutput) {
      input.value = currentOutput;
      window.__belbooreTools.showEmpty(output, 'Encoded / decoded result will appear here');
      window.__belbooreTools.clearErrorBox(errorDiv);
    } else {
      window.__belbooreTools.showEmpty(output, 'Nothing to swap');
    }
  });
</script>
