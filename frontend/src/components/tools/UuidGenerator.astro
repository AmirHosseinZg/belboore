---
import ToolPrimitives from './ToolPrimitives.astro';
import ToolUtils from './ToolUtils.astro';
import ToolWorkspace from './ToolWorkspace.astro';
---

<ToolPrimitives />
<ToolUtils />

<ToolWorkspace title="UUID Generator">
  <div class="tool-toolbar">
    <label class="tool-field__label" for="uuid-count" style="margin:0;display:flex;align-items:center;gap:var(--space-2)">
      Count
      <input id="uuid-count" class="tool-input" type="number" min="1" max="50" value="5" style="width:70px" />
    </label>
    <button type="button" id="uuid-generate" class="tool-btn tool-btn--primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      Generate
    </button>
    <button type="button" id="uuid-copy-all" class="tool-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      Copy All
    </button>
  </div>
  <div id="uuid-output" class="tool-output tool-output--empty" role="status" aria-live="polite">Click Generate to create UUIDs</div>
  <div class="tool-note">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    UUIDs are generated in your browser using <code>crypto.randomUUID()</code>. No data is ever sent anywhere.
  </div>
</ToolWorkspace>

<script>
  const countInput = document.getElementById('uuid-count') as HTMLInputElement;
  const output = document.getElementById('uuid-output')!;

  function showEmpty(text: string) {
    window.__belbooreTools.showEmpty(output, text);
  }

  function generateUUIDs(count: number): string[] {
    const uuids: string[] = [];
    for (let i = 0; i < count; i++) {
      uuids.push(crypto.randomUUID());
    }
    return uuids;
  }

  function renderUUIDs(uuids: string[]) {
    output.classList.remove('tool-output--empty');
    output.textContent = '';
    uuids.forEach(uuid => {
      const span = document.createElement('span');
      span.className = 'uuid-item';
      span.style.cssText = 'display:block;padding:var(--space-1) var(--space-2);border-radius:var(--radius-sm);cursor:pointer;transition:background var(--duration-fast) var(--ease-out)';
      span.setAttribute('title', 'Click to copy');
      span.setAttribute('tabindex', '0');
      span.setAttribute('role', 'button');
      span.setAttribute('aria-label', 'Copy UUID');
      span.dataset.uuid = uuid;
      span.textContent = '\u2192 ' + uuid;
      output.appendChild(span);
    });
  }

  function copyUUID(el: HTMLElement) {
    const uuid = el.dataset.uuid || el.textContent!.replace(/^\S+\s+/, '');
    navigator.clipboard.writeText(uuid).then(() => {
      const origText = el.textContent!;
      const check = document.createElement('span');
      check.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
      el.textContent = '';
      el.appendChild(check);
      el.style.color = '#10b981';
      setTimeout(() => {
        el.textContent = origText;
        el.style.color = '';
      }, 1500);
    }).catch(() => {});
  }

  document.getElementById('uuid-generate')!.addEventListener('click', () => {
    let count = parseInt(countInput.value, 10);
    if (isNaN(count) || count < 1) count = 1;
    if (count > 50) count = 50;
    countInput.value = String(count);
    const uuids = generateUUIDs(count);
    renderUUIDs(uuids);
  });

  document.getElementById('uuid-copy-all')!.addEventListener('click', () => {
    if (output.classList.contains('tool-output--empty')) return;
    const items = output.querySelectorAll('.uuid-item') as NodeListOf<HTMLElement>;
    const all = Array.from(items).map(el => el.dataset.uuid || el.textContent!.replace(/^\S+\s+/, '')).join('\n');
    if (!all) return;
    window.__belbooreTools.copyToClipboard(all, document.getElementById('uuid-copy-all')!, 1500);
  });

  output.addEventListener('click', async (e) => {
    const target = (e.target as HTMLElement).closest('.uuid-item') as HTMLElement | null;
    if (!target) return;
    copyUUID(target);
  });

  output.addEventListener('keydown', (e) => {
    const target = (e.target as HTMLElement).closest('.uuid-item') as HTMLElement | null;
    if (!target) return;
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      copyUUID(target);
    }
  });
</script>
