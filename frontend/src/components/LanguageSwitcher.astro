---
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props as Props;
const t = ui[lang];
const otherLang: Lang = lang === 'en' ? 'fa' : 'en';
const pathWithoutLang = pathname.replace(/^\/(en|fa)/, '') || '/';
const switchUrl = `/${otherLang}${pathWithoutLang}`;
---

<a   href={switchUrl}
  class="lang-switch"
  data-testid="lang-switch" aria-label={t['language.switchLabel']}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10" />
    <line x1="2" y1="12" x2="22" y2="12" />
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
  </svg>
  <span>{t['language.switch']}</span>
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    transition: all var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .lang-switch:hover {
    color: var(--text-primary);
    background: var(--surface-tertiary);
  }
</style>
