---
interface Props {
  id?: string;
  value?: number;
  max?: number;
  label?: string;
  className?: string;
  showValue?: boolean;
}

const {
  id,
  value = 0,
  max = 100,
  label = '',
  className = '',
  showValue = true,
} = Astro.props;

const safeMax = max > 0 ? max : 100;
const safeValue = Math.max(0, Math.min(value, safeMax));
const percent = Math.round((safeValue / safeMax) * 100);
---

<div id={id} class:list={['ui-progress', className]} data-ui-progress data-value={percent} role="status" aria-live="polite">
  {(label || showValue) && (
    <div class="ui-progress__head">
      {label && <span class="ui-progress__label">{label}</span>}
      {showValue && <span class="ui-progress__value" data-ui-progress-value>{percent}%</span>}
    </div>
  )}
  <div class="ui-progress__track" role="progressbar" aria-valuemin="0" aria-valuemax={safeMax} aria-valuenow={safeValue}>
    <span class="ui-progress__bar" style={`width:${percent}%`} data-ui-progress-bar></span>
  </div>
</div>

<script is:inline>
  if (!window.__belbooreUiProgressReady) {
    window.__belbooreUiProgressReady = true;
    window.__belbooreUiProgress = {
      setValue(target, value, max = 100) {
        const root = typeof target === 'string' ? document.getElementById(target) : target;
        if (!root) return;
        const safeMax = max > 0 ? max : 100;
        const safeValue = Math.max(0, Math.min(value, safeMax));
        const percent = Math.round((safeValue / safeMax) * 100);

        root.setAttribute('data-value', String(percent));

        const valueEl = root.querySelector('[data-ui-progress-value]');
        if (valueEl) valueEl.textContent = `${percent}%`;

        const track = root.querySelector('.ui-progress__track');
        if (track) {
          track.setAttribute('aria-valuemax', String(safeMax));
          track.setAttribute('aria-valuenow', String(safeValue));
        }

        const bar = root.querySelector('[data-ui-progress-bar]');
        if (bar) bar.style.width = `${percent}%`;
      },
    };
  }
</script>

<style>
  .ui-progress {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ui-progress__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .ui-progress__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ui-progress__value {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-tech-blue);
    font-family: var(--font-mono);
  }

  .ui-progress__track {
    width: 100%;
    height: 10px;
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .ui-progress__bar {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--color-tech-blue), var(--color-electric-cyan));
    transition: width 220ms var(--ease-out);
  }
</style>
