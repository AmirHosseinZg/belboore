---
interface Props {
  id: string;
  name?: string;
  checked?: boolean;
  disabled?: boolean;
  className?: string;
}

const {
  id,
  name,
  checked = false,
  disabled = false,
  className = '',
  ...rest
} = Astro.props;
---

<label class:list={['ui-checkbox', className]} for={id}>
  <input
    id={id}
    name={name}
    type="checkbox"
    class="ui-checkbox__input"
    checked={checked}
    disabled={disabled}
    {...rest}
  />
  <span class="ui-checkbox__box" aria-hidden="true">
    <svg class="ui-checkbox__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
      <path d="M20 6 9 17l-5-5"></path>
    </svg>
  </span>
  <span class="ui-checkbox__label"><slot /></span>
</label>

<style>
  .ui-checkbox {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    user-select: none;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
  }

  .ui-checkbox__input {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .ui-checkbox__box {
    inline-size: 18px;
    block-size: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--border-default);
    border-radius: var(--radius-sm);
    background: var(--surface-primary);
    color: white;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .ui-checkbox__icon {
    opacity: 0;
    transform: scale(0.65);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .ui-checkbox:hover .ui-checkbox__box {
    border-color: color-mix(in srgb, var(--color-tech-blue) 40%, var(--border-default));
    transform: translateY(-1px);
  }

  .ui-checkbox__input:checked + .ui-checkbox__box {
    border-color: var(--color-tech-blue);
    background: linear-gradient(135deg, var(--color-tech-blue), var(--color-electric-cyan));
  }

  .ui-checkbox__input:checked + .ui-checkbox__box .ui-checkbox__icon {
    opacity: 1;
    transform: scale(1);
  }

  .ui-checkbox__input:focus-visible + .ui-checkbox__box {
    box-shadow:
      0 0 0 3px var(--color-tech-blue-subtle),
      var(--shadow-sm);
  }

  .ui-checkbox__input:disabled + .ui-checkbox__box,
  .ui-checkbox__input:disabled ~ .ui-checkbox__label {
    opacity: 0.55;
    cursor: not-allowed;
  }

  [data-theme='dark'] .ui-checkbox__box {
    background: var(--surface-elevated);
    border-color: var(--border-default);
  }
</style>
