---
import { getNav } from '../../data/navigation';
import Icon from '../icons/Icon.astro';
const { lang, pathname } = Astro.props;
const otherLang = lang === 'fa' ? 'en' : 'fa';
const switchPath = pathname.replace(`/${lang}/`, `/${otherLang}/`);
const nav = getNav(lang);
---
<header class="app-header">
  <div class="container shell">
    <a class="brand" href={`/${lang}/`}><span class="brand-dot"></span><strong>Belboore</strong><small>بل بوره</small></a>
    <nav>{nav.map((i) => <a class={pathname === i.href ? 'active' : ''} href={i.href}>{i.label}</a>)}</nav>
    <details class="settings">
      <summary class="pill icon-btn" aria-label={lang==='fa'?'تنظیمات':'Settings'}><Icon name="settings" /></summary>
      <div class="menu card">
        <a class="menu-item" href={switchPath}><span>{lang==='fa'?'زبان':'Language'}</span><strong>{lang === 'fa' ? 'English' : 'فارسی'}</strong></a>
        <button id="theme-toggle" class="menu-item" type="button"><span>{lang==='fa'?'تم':'Theme'}</span><strong id="theme-label"></strong></button>
      </div>
    </details>
  </div>
</header>
<script>
  const key='belboore-theme';
  const root=document.documentElement;
  const label=document.getElementById('theme-label');
  const update=()=>{const dark = root.dataset.theme === 'dark'; label.textContent = dark ? 'Dark' : 'Light';};
  const saved=localStorage.getItem(key); if(saved) root.dataset.theme=saved; update();
  document.getElementById('theme-toggle')?.addEventListener('click',()=>{root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark'; localStorage.setItem(key, root.dataset.theme); update();});
</script>
