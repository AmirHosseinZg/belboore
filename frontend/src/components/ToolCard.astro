---
import type { Tool } from '../data/tools';
import type { Lang } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  tool: Tool;
  lang: Lang;
}

const { tool, lang } = Astro.props;
const t = ui[lang];
const name = tool.name[lang];
const description = tool.description[lang];
const toolUrl = tool.type === 'builtin'
  ? `/${lang}/tools/${tool.slug}`
  : tool.url || '#';
const isExternal = tool.type === 'external';
---

<a
  href={toolUrl}
  class={`tool-card surface-card surface-card--interactive ${isExternal ? 'tool-card--external' : ''}`}
  {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <div class="tool-card__header">
    <span class="tool-card__icon">{tool.icon}</span>
    <span class="tool-card__badge">
      {tool.type === 'builtin' ? t['tools.type.builtin'] : t['tools.type.external']}
    </span>
  </div>
  <div class="tool-card__body">
    <h3 class="tool-card__title">{name}</h3>
    <p class="tool-card__desc">{description}</p>
  </div>
  <div class="tool-card__footer">
    <span class="tool-card__action">
      {tool.type === 'builtin' ? t['tools.useNow'] : t['tools.visit']}
      {isExternal ? (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      ) : (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      )}
    </span>
  </div>
</a>

<style>
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    height: 100%;
  }

  .tool-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .tool-card__icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .tool-card__badge {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    background: var(--surface-tertiary);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tool-card--external .tool-card__badge {
    background: var(--color-electric-cyan-subtle);
    color: var(--color-electric-cyan);
  }

  .tool-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .tool-card__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
  }

  .tool-card__desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .tool-card__footer {
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
  }

  .tool-card__action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-link);
    transition: gap var(--duration-fast) var(--ease-out);
  }

  .tool-card:hover .tool-card__action {
    gap: var(--space-3);
  }
</style>
