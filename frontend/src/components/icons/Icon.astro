---
const { name, class: className = 'icon' } = Astro.props;
---
<svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {name === 'search' && <><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></>}
  {name === 'settings' && (
  <>
    <circle cx="12" cy="12" r="3" />
    <path d="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.06-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.03 7.03 0 0 0-1.63-.94l-.36-2.54a.5.5 0 0 0-.5-.42h-3.84a.5.5 0 0 0-.5.42l-.36 2.54c-.58.22-1.12.53-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.84a.5.5 0 0 0 .12.64l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94L2.83 14.52a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .6.22l2.39-.96c.51.41 1.05.72 1.63.94l.36 2.54a.5.5 0 0 0 .5.42h3.84a.5.5 0 0 0 .5-.42l.36-2.54c.58-.22 1.12-.53 1.63-.94l2.39.96a.5.5 0 0 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58Z" />
  </>
)}
  {name === 'moon' && <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 1 0 9.8 9.8Z"/>}
  {name === 'sun' && <><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></>}
  {name === 'cach' && <><rect x="4" y="4" width="16" height="16" rx="4"/><path d="M8 9h8M8 13h8M8 17h5"/><circle cx="17" cy="7" r="1.2"/></>}
  {name === 'haamcall' && <><rect x="4" y="4" width="16" height="16" rx="4"/><path d="M9 9v6M15 9v6"/><path d="M9 12h6"/></>}
  {name === 'excalidraw' && <><path d="M6 6h12v12H6z"/><path d="m8 8 8 8M16 8l-8 8"/></>}
  {name === 'image-compressor' && <><rect x="3" y="4" width="18" height="14" rx="3"/><path d="M8 14h8"/><path d="M8 10h8"/><path d="M12 18v3"/></>}
  {name === 'image-converter' && <><rect x="3" y="4" width="8" height="8" rx="2"/><rect x="13" y="12" width="8" height="8" rx="2"/><path d="M11 8h2m0 0-1.5-1.5M13 8l-1.5 1.5"/></>}
  {name === 'image-resizer' && <><rect x="4" y="5" width="16" height="12" rx="2"/><path d="M8 9h8M8 13h5"/><path d="M15 18h5v-5"/></>}
  {name === 'text-case-converter' && <><path d="M5 18 9 6l4 12"/><path d="M6.2 14h5.6"/><path d="M15 9h4m-2 0v9"/></>}
  {name === 'json-formatter-validator' && <><path d="M8 4C6 4 6 6 6 7.5v2c0 1-.5 1.5-1.5 1.5C5.5 11 6 11.5 6 12.5v2C6 16 6 18 8 18"/><path d="M16 4c2 0 2 2 2 3.5v2c0 1 .5 1.5 1.5 1.5-1 0-1.5.5-1.5 1.5v2c0 1.5 0 3.5-2 3.5"/><path d="M11 9h2M11 13h2"/></>}
  {name === 'image-tools' && <><rect x="3" y="4" width="18" height="14" rx="2"/><circle cx="9" cy="9" r="1.2"/><path d="m4 15 5-4 3 2 4-3 4 5"/></>}
  {name === 'text-tools' && <><path d="M4 7h16M8 7v10M12 7v10M16 7v10"/></>}
  {name === 'file-tools' && <><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/></>}
  {name === 'network-tools' && <><circle cx="12" cy="12" r="3"/><path d="M3 12h6m6 0h6M12 3v6m0 6v6"/></>}
  {name === 'ai-tools' && <><path d="M12 3 9 9l3 3 3-3-3-6Z"/><path d="M6 14h12l-2 7H8Z"/></>}
  {name === 'dev-tools' && <><path d="m8 8-4 4 4 4M16 8l4 4-4 4"/><path d="m13 5-2 14"/></>}
  {name === 'calculators' && <><rect x="6" y="3" width="12" height="18" rx="2"/><path d="M9 8h6M9 12h2m2 0h2m-6 4h2m2 0h2"/></>}
  {name === 'productivity-tools' && <><circle cx="12" cy="12" r="8"/><path d="M12 8v5l3 2"/></>}
</svg>
