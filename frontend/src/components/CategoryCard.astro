---
import type { Category } from '../data/categories';
import type { Lang } from '../i18n/utils';
import { tools } from '../data/tools';

interface Props {
  category: Category;
  lang: Lang;
}

const { category, lang } = Astro.props;
const name = category.name[lang];
const description = category.description[lang];
const toolCount = tools.filter(t => t.category === category.slug).length;
const hasImageIcon = Boolean(category.iconPath);
const countLabel = lang === 'fa'
  ? 'ابزار'
  : toolCount === 1
    ? 'tool'
    : 'tools';
const densityLabel = lang === 'fa'
  ? (toolCount >= 4 ? 'پربار' : toolCount >= 2 ? 'منتخب' : 'در حال گسترش')
  : (toolCount >= 4 ? 'Popular' : toolCount >= 2 ? 'Curated' : 'Growing');
---

<a href={`/${lang}/categories/${category.slug}`} class="category-card surface-card surface-card--interactive">
  <div class="category-card__media">
    {hasImageIcon ? (
      <img
        src={category.iconPath}
        alt=""
        width="88"
        height="88"
        loading="lazy"
        decoding="async"
        class="category-card__image"
      />
    ) : (
      <span class="category-card__icon" aria-hidden="true">{category.icon}</span>
    )}
    <span class="category-card__pill">{densityLabel}</span>
  </div>
  <div class="category-card__body">
    <h3 class="category-card__title">{name}</h3>
    <p class="category-card__desc">{description}</p>
  </div>
  <div class="category-card__footer">
    <span class="category-card__cta">
      {lang === 'fa' ? 'مشاهده دسته' : 'Explore category'}
      <img
        src="/general-icons/arrow/arrow-blue.svg"
        alt=""
        width="14"
        height="14"
        loading="lazy"
        class="category-card__cta-arrow"
        aria-hidden="true"
      />
    </span>
    <span class="category-card__count">{toolCount} {countLabel}</span>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-normal) var(--ease-out);
    min-height: 100%;
  }

  .category-card__media {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 88px;
  }

  .category-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 22px;
    font-size: 2rem;
    line-height: 1;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0)),
      linear-gradient(135deg, var(--color-tech-blue-subtle), rgba(0, 212, 255, 0.12));
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-sm);
  }

  .category-card__image {
    width: 88px;
    height: 88px;
    object-fit: contain;
    filter: drop-shadow(0 12px 20px rgba(0, 82, 255, 0.14));
  }

  .category-card__pill {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-full);
    background: var(--color-success-subtle);
    color: var(--color-success);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    line-height: 1;
    white-space: nowrap;
  }

  .category-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .category-card__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
  }

  .category-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
    flex-direction: row-reverse;
  }

  .category-card__count {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
  }

  .category-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-link);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
    transition:
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .category-card__cta-arrow {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transform: rotate(180deg);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .category-card:hover .category-card__cta {
    color: var(--text-link-hover);
  }

  .category-card:hover .category-card__cta-arrow {
    transform: rotate(180deg) translateX(2px);
  }

  [dir="rtl"] .category-card:hover .category-card__cta-arrow {
    transform: rotate(180deg) translateX(-2px);
  }
</style>
