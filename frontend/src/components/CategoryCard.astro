---
import type { Category } from '../data/categories';
import type { Lang } from '../i18n/utils';
import { tools } from '../data/tools';

interface Props {
  category: Category;
  lang: Lang;
}

const { category, lang } = Astro.props;
const name = category.name[lang];
const description = category.description[lang];
const toolCount = tools.filter(t => t.category === category.slug).length;
---

<a href={`/${lang}/categories/${category.slug}`} class="category-card surface-card surface-card--interactive">
  <span class="category-card__icon">{category.icon}</span>
  <div class="category-card__body">
    <h3 class="category-card__title">{name}</h3>
    <p class="category-card__desc">{description}</p>
  </div>
  <span class="category-card__count">{toolCount} {lang === 'fa' ? 'ابزار' : (toolCount === 1 ? 'tool' : 'tools')}</span>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .category-card__icon {
    font-size: 2rem;
    line-height: 1;
  }

  .category-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .category-card__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
  }

  .category-card__desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .category-card__count {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
  }
</style>
