---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ui } from '../../i18n/ui';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fa' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = ui[lang];
const dir = lang === 'fa' ? 'rtl' : 'ltr';
const pathname = `/${lang}/contribute`;
---

<BaseLayout
  lang={lang}
  pathname={pathname}
  title={t['contribute.heading']}
  description={t['contribute.description']}
>
  <div class="page" dir={dir}>
    <div class="container">
      <header class="page-header">
        <h1 class="page-header__title">{t['contribute.heading']}</h1>
        <p class="page-header__desc">{t['contribute.description']}</p>
      </header>

      <div class="contribute-grid">
        <div class="contribute-card surface-card">
          <div class="contribute-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-tech-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
            </svg>
          </div>
          <h2 class="contribute-card__title">{t['contribute.code']}</h2>
          <p class="contribute-card__text">{t['contribute.codeText']}</p>
          <a href="https://github.com" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>

        <div class="contribute-card surface-card">
          <div class="contribute-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric-cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" />
            </svg>
          </div>
          <h2 class="contribute-card__title">{t['contribute.suggest']}</h2>
          <p class="contribute-card__text">{t['contribute.suggestText']}</p>
          <a href="https://github.com" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
            Open Issue
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        </div>

        <div class="contribute-card surface-card">
          <div class="contribute-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-tech-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
          </div>
          <h2 class="contribute-card__title">{t['contribute.translate']}</h2>
          <p class="contribute-card__text">{t['contribute.translateText']}</p>
          <a href="https://github.com" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
            GitHub
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding-block: var(--space-12);
  }

  .page-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .page-header__title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    margin-bottom: var(--space-4);
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    max-width: 480px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .contribute-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    max-width: 960px;
    margin: 0 auto;
  }

  .contribute-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8);
  }

  .contribute-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: var(--color-tech-blue-subtle);
  }

  .contribute-card__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
  }

  .contribute-card__text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  @media (max-width: 768px) {
    .contribute-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
