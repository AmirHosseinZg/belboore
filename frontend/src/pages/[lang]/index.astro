---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ui } from '../../i18n/ui';
import { languages, defaultLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { tools, getFeaturedTools } from '../../data/tools';
import { categories } from '../../data/categories';
import ToolCard from '../../components/ToolCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import RecentTools from '../../components/RecentTools.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fa' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = ui[lang];
const dir = lang === 'fa' ? 'rtl' : 'ltr';
const pathname = `/${lang}`;

const featuredTools = getFeaturedTools().slice(0, 6);
const sortedCategories = [...categories].sort((a, b) => a.order - b.order);
---

<BaseLayout lang={lang} pathname={pathname}>
  <div class="home" dir={dir}>

    <!-- ═══ HERO SECTION ═══ -->
    <section class="hero">
      <div class="hero__bg">
        <div class="hero__glow hero__glow--blue"></div>
        <div class="hero__glow hero__glow--cyan"></div>
      </div>
      <div class="container hero__content">
        <div class="hero__badge animate-fade-in">
          <span class="hero__badge-dot"></span>
          {t['home.builtin.badge']} + {t['home.external.badge']}
        </div>
        <h1 class="hero__title animate-fade-in-up stagger-1">
          {t['home.hero.title']}
          <span class="text-gradient">{t['home.hero.titleEmphasis']}</span>
        </h1>
        <p class="hero__subtitle animate-fade-in-up stagger-2">
          {t['home.hero.subtitle']}
        </p>
        <div class="hero__stats animate-fade-in-up stagger-2">
          <div class="hero__stat">
            <span class="hero__stat-num" data-hero-counter data-counter-value={tools.length} data-counter-suffix="+">{tools.length}+</span>
            <span class="hero__stat-label">{lang === 'fa' ? 'ابزار' : 'Tools'}</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-num" data-hero-counter data-counter-value={categories.length}>{categories.length}</span>
            <span class="hero__stat-label">{lang === 'fa' ? 'دسته‌بندی' : 'Categories'}</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-num" data-hero-counter data-counter-value={tools.filter(t => t.type === 'builtin').length}>{tools.filter(t => t.type === 'builtin').length}</span>
            <span class="hero__stat-label">{lang === 'fa' ? 'داخلی' : 'Built-in'}</span>
          </div>
        </div>
        <div class="hero__actions animate-fade-in-up stagger-3">
          <a href={`/${lang}/tools`} class="btn btn-primary btn-lg">
            {t['home.hero.cta']}
            <img class="hero__cta-icon" src="/general-icons/click/click-white.svg" alt="" aria-hidden="true" />
          </a>
          <a href={`/${lang}/about`} class="btn btn-secondary btn-lg">
            {t['home.hero.ctaSecondary']}
          </a>
        </div>

        <!-- Search -->
        <div class="hero__search animate-fade-in-up stagger-4">
          <div class="search-box">
            <svg class="search-box__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
            </svg>
            <input
              type="text"
              id="hero-search"
              class="search-box__input"
              data-testid="hero-search"
              placeholder={t['home.search.placeholder']}
              autocomplete="off"
            />
            <div class="search-box__shortcut">
              <kbd>Ctrl</kbd> + <kbd>K</kbd>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURED TOOLS ═══ -->
    <section class="section featured">
      <div class="container">
        <div class="section-header">
          <h2 class="section-header__title">{t['home.featured.title']}</h2>
          <p class="section-header__subtitle">{t['home.featured.subtitle']}</p>
          <a href={`/${lang}/tools`} class="section-header__link">
            {t['home.featured.viewAll']}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="tools-grid">
          {featuredTools.map(tool => (
            <ToolCard tool={tool} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CATEGORIES ═══ -->
    <section class="section section-sm categories-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-header__title">{t['home.categories.title']}</h2>
          <p class="section-header__subtitle">{t['home.categories.subtitle']}</p>
        </div>
        <div class="categories-grid">
          {sortedCategories.map(cat => (
            <CategoryCard category={cat} lang={lang} />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ RECENT TOOLS ═══ -->
    <section class="section section-sm">
      <div class="container">
        <RecentTools />
      </div>
    </section>

    <!-- ═══ BUILT-IN vs EXTERNAL ═══ -->
    <section class="section section-lg tools-types">
      <div class="container">
        <div class="tools-types__grid">
          <div class="tools-types__card tools-types__card--builtin surface-card">
            <div class="tools-types__icon-wrap tools-types__icon-wrap--builtin">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
              </svg>
            </div>
            <h3 class="tools-types__title">{t['home.builtin.title']}</h3>
            <p class="tools-types__desc">{t['home.builtin.subtitle']}</p>
            <span class="tools-types__badge tools-types__badge--builtin">{t['home.builtin.badge']}</span>
          </div>
          <div class="tools-types__card tools-types__card--external surface-card">
            <div class="tools-types__icon-wrap tools-types__icon-wrap--external">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </div>
            <h3 class="tools-types__title">{t['home.external.title']}</h3>
            <p class="tools-types__desc">{t['home.external.subtitle']}</p>
            <span class="tools-types__badge tools-types__badge--external">{t['home.external.badge']}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA BANNER ═══ -->
    <section class="section cta">
      <div class="container">
        <div class="cta__banner surface-glass glow-blue">
          <div class="cta__content">
            <h2 class="cta__title">{t['home.cta.title']}</h2>
            <p class="cta__subtitle">{t['home.cta.subtitle']}</p>
          </div>
          <a href="https://github.com" class="btn btn-accent btn-lg" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            {t['home.cta.button']}
          </a>
        </div>
      </div>
    </section>

  </div>

  <script>
    (function() {
      const lang = document.documentElement.lang;
      const searchInput = document.getElementById('hero-search');

      if (searchInput) {
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && searchInput.value.trim()) {
            window.location.href = '/' + lang + '/tools?q=' + encodeURIComponent(searchInput.value.trim());
          }
        });

        document.addEventListener('keydown', (e) => {
          if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            searchInput.focus();
          }
        });
      }

      const counters = Array.from(document.querySelectorAll('[data-hero-counter]'));
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function setCounterValue(el, value) {
        const suffix = el.getAttribute('data-counter-suffix') || '';
        el.textContent = String(value) + suffix;
      }

      function animateCounter(el) {
        const target = Number(el.getAttribute('data-counter-value') || '0');
        const duration = 900;
        const startTime = performance.now();

        function frame(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          setCounterValue(el, Math.round(target * eased));

          if (progress < 1) {
            requestAnimationFrame(frame);
          }
        }

        requestAnimationFrame(frame);
      }

      if (prefersReducedMotion) {
        counters.forEach(el => setCounterValue(el, Number(el.getAttribute('data-counter-value') || '0')));
      } else {
        counters.forEach(el => setCounterValue(el, 0));
        setTimeout(() => counters.forEach(animateCounter), 350);
      }
    })();
  </script>
</BaseLayout>

<style>
  /* ═══ HERO ═══ */
  .hero {
    position: relative;
    padding: var(--space-24) 0 var(--space-16);
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 82, 255, 0.1), transparent 42%),
      linear-gradient(180deg, rgba(232, 240, 255, 0.54) 0%, rgba(247, 249, 255, 0.18) 58%, transparent 100%);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 160px;
    pointer-events: none;
    z-index: 0;
    background: linear-gradient(180deg, transparent 0%, var(--surface-secondary) 88%);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(150px);
    opacity: 0.12;
  }

  .hero__glow--blue {
    width: 680px;
    height: 680px;
    background: var(--color-tech-blue);
    top: -260px;
    right: -100px;
  }

  .hero__glow--cyan {
    width: 620px;
    height: 620px;
    background: var(--color-electric-cyan);
    bottom: -280px;
    left: -150px;
    opacity: 0.06;
  }

  [dir="rtl"] .hero__glow--blue {
    left: -100px;
    right: auto;
  }

  [dir="rtl"] .hero__glow--cyan {
    right: -150px;
    left: auto;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-4);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-tech-blue);
    box-shadow: 0 0 8px var(--color-tech-blue-glow);
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, var(--text-6xl));
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    max-width: 720px;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    max-width: 560px;
    margin: 0;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__cta-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    margin-top: var(--space-10);
  }

  .hero__stat {
    text-align: center;
  }

  .hero__stat-num {
    display: block;
    font-size: var(--text-2xl);
    font-weight: var(--weight-extrabold);
    color: var(--text-primary);
    line-height: 1;
  }

  .hero__stat-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    margin-top: var(--space-1);
  }

  .hero__stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border-default);
  }

  @media (max-width: 480px) {
    .hero__stats {
      gap: var(--space-4);
    }

    .hero__stat-num {
      font-size: var(--text-xl);
    }
  }

  .hero__search {
    width: 100%;
    max-width: 500px;
    margin-top: var(--space-4);
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--surface-primary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-5);
    box-shadow: var(--shadow-md);
    transition: all var(--duration-normal) var(--ease-out);
  }

  [dir="rtl"] .search-box {
    padding: var(--space-2) var(--space-5) var(--space-2) var(--space-2);
  }

  .search-box:focus-within {
    border-color: var(--color-tech-blue);
    box-shadow: var(--shadow-lg), var(--shadow-glow-blue);
  }

  .search-box__icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-box__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--text-base);
    color: var(--text-primary);
    font-family: inherit;
    line-height: 1.5;
  }

  .search-box__input::placeholder {
    color: var(--text-muted);
  }

  .search-box__shortcut {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background: var(--surface-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-box__shortcut kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }

  @media (max-width: 480px) {
    .search-box__shortcut {
      display: none;
    }
  }

  /* ═══ SECTION HEADER ═══ */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .section-header__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
  }

  .section-header__subtitle {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: 0;
    flex-basis: 100%;
  }

  .section-header__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-link);
    text-decoration: none;
    white-space: nowrap;
    transition: gap var(--duration-fast) var(--ease-out);
  }

  .section-header__link:hover {
    gap: var(--space-3);
  }

  /* ═══ TOOLS GRID ═══ */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ CATEGORIES GRID ═══ */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ TOOLS TYPES ═══ */
  .tools-types__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .tools-types__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-10);
  }

  .tools-types__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
  }

  .tools-types__icon-wrap--builtin {
    background: var(--color-tech-blue-subtle);
    color: var(--color-tech-blue);
  }

  .tools-types__icon-wrap--external {
    background: var(--color-electric-cyan-subtle);
    color: var(--color-electric-cyan);
  }

  .tools-types__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
  }

  .tools-types__desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .tools-types__badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-full);
  }

  .tools-types__badge--builtin {
    background: var(--color-tech-blue-subtle);
    color: var(--color-tech-blue);
  }

  .tools-types__badge--external {
    background: var(--color-electric-cyan-subtle);
    color: var(--color-electric-cyan);
  }

  @media (max-width: 640px) {
    .tools-types__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ CTA BANNER ═══ */
  .cta__banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-10);
    padding: var(--space-12) var(--space-16);
    border-radius: var(--radius-2xl);
  }

  .cta__title {
    font-size: clamp(1.5rem, 3vw, var(--text-3xl));
    font-weight: var(--weight-extrabold);
    margin-bottom: var(--space-2);
  }

  .cta__subtitle {
    font-size: var(--text-base);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .cta__banner {
      flex-direction: column;
      text-align: center;
      padding: var(--space-10) var(--space-8);
    }
  }
</style>
