---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';
import type { Lang } from '../../../i18n/utils';
import { categories } from '../../../data/categories';
import { tools } from '../../../data/tools';
import CategoryCard from '../../../components/CategoryCard.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fa' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = ui[lang];
const dir = lang === 'fa' ? 'rtl' : 'ltr';
const pathname = `/${lang}/categories`;
const sortedCategories = [...categories].sort((a, b) => a.order - b.order);
const activeCategories = sortedCategories.filter(category =>
  tools.some(tool => tool.category === category.slug)
);
const totalTools = tools.length;
---

<BaseLayout
  lang={lang}
  pathname={pathname}
  title={t['categories.heading']}
  description={t['categories.description']}
>
  <div class="page" dir={dir}>
    <div class="container">
      <header class="page-header">
        <div class="page-header__eyebrow">
          {lang === 'fa' ? 'نقشه ابزارها' : 'Browse the toolbox'}
        </div>
        <div class="page-header__content">
          <div class="page-header__copy">
            <h1 class="page-header__title">{t['categories.heading']}</h1>
            <p class="page-header__desc">{t['categories.description']}</p>
          </div>
          <div class="page-header__stats" data-counter-root>
            <div class="page-header__stat">
              <span class="page-header__stat-value" data-count-to={sortedCategories.length}>0</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'دسته' : 'Categories'}</span>
            </div>
            <div class="page-header__stat">
              <span class="page-header__stat-value" data-count-to={activeCategories.length}>0</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'فعال' : 'Active'}</span>
            </div>
            <div class="page-header__stat">
              <span class="page-header__stat-value" data-count-to={totalTools}>0</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'ابزار' : 'Tools'}</span>
            </div>
          </div>
        </div>
      </header>

      {sortedCategories.length > 0 ? (
        <div class="categories-grid">
          {sortedCategories.map(cat => (
            <CategoryCard category={cat} lang={lang} />
          ))}
        </div>
      ) : (
        <p class="empty-state">{t['categories.empty']}</p>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  function initCategoryCounters() {
    const root = document.querySelector('[data-counter-root]');
    if (!root || root.hasAttribute('data-counted')) return;

    const values = Array.from(root.querySelectorAll('[data-count-to]')) as HTMLElement[];
    if (values.length === 0) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const formatter = new Intl.NumberFormat(document.documentElement.lang || 'fa');

    function setValue(el: HTMLElement, value: number) {
      el.textContent = formatter.format(value);
    }

    function runCounters() {
      root.setAttribute('data-counted', 'true');

      values.forEach((el) => {
        const target = Number(el.dataset.countTo || 0);
        if (reduceMotion || target <= 0) {
          setValue(el, target);
          return;
        }

        const duration = 900;
        const start = performance.now();

        function frame(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          setValue(el, Math.round(target * eased));

          if (progress < 1) {
            requestAnimationFrame(frame);
          }
        }

        requestAnimationFrame(frame);
      });
    }

    if (!('IntersectionObserver' in window)) {
      runCounters();
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries.some(entry => entry.isIntersecting)) {
        observer.disconnect();
        runCounters();
      }
    }, { threshold: 0.35 });

    observer.observe(root);
  }

  initCategoryCounters();
  document.addEventListener('astro:after-swap', initCategoryCounters);
</script>

<style>
  .page {
    position: relative;
    padding-block: var(--space-12) var(--space-16);
    min-height: 60vh;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .page-header {
    margin-bottom: var(--space-14, 56px);
    text-align: center;
  }

  .page-header__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 var(--space-4);
    margin-bottom: var(--space-5);
    border-radius: var(--radius-full);
    background: var(--color-tech-blue-subtle);
    color: var(--color-tech-blue);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-header__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-7, 28px);
  }

  .page-header__copy {
    max-width: 680px;
  }

  .page-header__title {
    position: relative;
    display: inline-block;
    font-size: var(--text-5xl);
    font-weight: var(--weight-extrabold);
    margin-bottom: var(--space-3);
    letter-spacing: 0;
  }

  .page-header__title::before {
    content: '';
    position: absolute;
    inset: 50% auto auto 50%;
    width: min(800px, 86vw);
    height: 250px;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(0, 82, 255, 0.07), rgba(0, 212, 255, 0.06) 42%, transparent 72%);
    pointer-events: none;
    z-index: -1;
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    max-width: 620px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .page-header__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: min(760px, 100%);
    gap: 0;
    padding: var(--space-2);
    background: transparent;
  }

  .page-header__stat {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 96px;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
  }

  .page-header__stat + .page-header__stat::before {
    content: '';
    position: absolute;
    inset-block: 20%;
    inset-inline-start: 0;
    width: 1px;
    background: var(--border-subtle);
  }

  .page-header__stat-value {
    font-variant-numeric: tabular-nums;
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--text-primary);
    line-height: 1;
  }

  .page-header__stat-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .page {
      padding-block: var(--space-10) var(--space-12);
    }

    .page-header {
      margin-bottom: var(--space-10);
    }

    .page-header__title {
      font-size: var(--text-4xl);
    }

    .page-header__stats {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .page-header__stat {
      min-height: 84px;
    }

    .page-header__stat + .page-header__stat::before {
      inset-block: auto;
      inset-inline: var(--space-5);
      top: 0;
      width: auto;
      height: 1px;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    text-align: center;
    padding: var(--space-20);
    color: var(--text-muted);
    font-size: var(--text-lg);
  }
</style>
