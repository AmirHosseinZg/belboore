---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';
import type { Lang } from '../../../i18n/utils';
import { categories } from '../../../data/categories';
import { tools } from '../../../data/tools';
import CategoryCard from '../../../components/CategoryCard.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fa' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = ui[lang];
const dir = lang === 'fa' ? 'rtl' : 'ltr';
const pathname = `/${lang}/categories`;
const sortedCategories = [...categories].sort((a, b) => a.order - b.order);
const activeCategories = sortedCategories.filter(category =>
  tools.some(tool => tool.category === category.slug)
);
const totalTools = tools.length;
---

<BaseLayout
  lang={lang}
  pathname={pathname}
  title={t['categories.heading']}
  description={t['categories.description']}
>
  <div class="page" dir={dir}>
    <div class="container">
      <header class="page-header">
        <div class="page-header__eyebrow">
          {lang === 'fa' ? 'نقشه ابزارها' : 'Browse the toolbox'}
        </div>
        <div class="page-header__content">
          <div class="page-header__copy">
            <h1 class="page-header__title">{t['categories.heading']}</h1>
            <p class="page-header__desc">{t['categories.description']}</p>
          </div>
          <div class="page-header__stats surface-glass">
            <div class="page-header__stat">
              <span class="page-header__stat-value">{sortedCategories.length}</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'دسته' : 'Categories'}</span>
            </div>
            <div class="page-header__stat">
              <span class="page-header__stat-value">{activeCategories.length}</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'فعال' : 'Active'}</span>
            </div>
            <div class="page-header__stat">
              <span class="page-header__stat-value">{totalTools}</span>
              <span class="page-header__stat-label">{lang === 'fa' ? 'ابزار' : 'Tools'}</span>
            </div>
          </div>
        </div>
      </header>

      {sortedCategories.length > 0 ? (
        <div class="categories-grid">
          {sortedCategories.map(cat => (
            <CategoryCard category={cat} lang={lang} />
          ))}
        </div>
      ) : (
        <p class="empty-state">{t['categories.empty']}</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    position: relative;
    padding-block: var(--space-12) var(--space-16);
    min-height: 60vh;
    overflow: hidden;
  }

  .page::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 50%;
    width: min(720px, 90vw);
    height: 280px;
    transform: translateX(-50%);
    background:
      radial-gradient(circle at center, rgba(0, 82, 255, 0.12), transparent 62%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .page-header {
    margin-bottom: var(--space-12);
  }

  .page-header__eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 var(--space-4);
    margin-bottom: var(--space-5);
    border-radius: var(--radius-full);
    background: var(--color-tech-blue-subtle);
    color: var(--color-tech-blue);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-header__content {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.85fr);
    gap: var(--space-8);
    align-items: end;
  }

  .page-header__copy {
    max-width: 680px;
  }

  .page-header__title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: var(--weight-extrabold);
    margin-bottom: var(--space-4);
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    max-width: 560px;
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .page-header__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    padding: var(--space-5);
    border-radius: var(--radius-xl);
  }

  .page-header__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.52);
    border: 1px solid var(--surface-glass-border);
  }

  [data-theme='dark'] .page-header__stat {
    background: rgba(11, 19, 43, 0.52);
  }

  .page-header__stat-value {
    font-size: var(--text-2xl);
    font-weight: var(--weight-extrabold);
    color: var(--text-primary);
  }

  .page-header__stat-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .page-header__content {
      grid-template-columns: 1fr;
    }

    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .page {
      padding-block: var(--space-10) var(--space-12);
    }

    .page-header {
      margin-bottom: var(--space-10);
    }

    .page-header__stats {
      grid-template-columns: 1fr;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    text-align: center;
    padding: var(--space-20);
    color: var(--text-muted);
    font-size: var(--text-lg);
  }
</style>
