---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';
import type { Lang } from '../../../i18n/utils';
import { tools, getTool, getToolsByCategory } from '../../../data/tools';
import ToolCard from '../../../components/ToolCard.astro';
import JsonFormatter from '../../../components/tools/JsonFormatter.astro';
import Base64Encoder from '../../../components/tools/Base64Encoder.astro';
import UrlEncoder from '../../../components/tools/UrlEncoder.astro';
import UuidGenerator from '../../../components/tools/UuidGenerator.astro';
import PasswordGenerator from '../../../components/tools/PasswordGenerator.astro';
import CaseConverter from '../../../components/tools/CaseConverter.astro';
import WordCounter from '../../../components/tools/WordCounter.astro';
import QrGenerator from '../../../components/tools/QrGenerator.astro';
import LoremIpsum from '../../../components/tools/LoremIpsum.astro';
import LineSorter from '../../../components/tools/LineSorter.astro';
import ColorConverter from '../../../components/tools/ColorConverter.astro';
import HashGenerator from '../../../components/tools/HashGenerator.astro';
import TimestampConverter from '../../../components/tools/TimestampConverter.astro';
import UnitConverter from '../../../components/tools/UnitConverter.astro';
import MarkdownEditor from '../../../components/tools/MarkdownEditor.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fa' } },
  ].flatMap(({ params }) =>
    tools.map(tool => ({
      params: { ...params, slug: tool.slug },
    }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const t = ui[lang];
const dir = lang === 'fa' ? 'rtl' : 'ltr';
const pathname = `/${lang}/tools/${slug}`;

const tool = getTool(slug);

if (!tool) {
  return Astro.redirect(`/${lang}/tools`);
}

const name = tool.name[lang];
const desc = tool.description[lang];
const longDesc = tool.longDescription[lang];
const howToUse = tool.howToUse?.[lang];
const tags = tool.tags[lang];

const relatedTools = getToolsByCategory(tool.category)
  .filter(t => t.slug !== tool.slug)
  .slice(0, 4);

const toolComponentMap: Record<string, any> = {
  'json-formatter': JsonFormatter,
  'base64-encoder': Base64Encoder,
  'url-encoder': UrlEncoder,
  'uuid-generator': UuidGenerator,
  'password-generator': PasswordGenerator,
  'case-converter': CaseConverter,
  'word-counter': WordCounter,
  'qr-code-generator': QrGenerator,
  'lorem-ipsum': LoremIpsum,
  'line-sorter': LineSorter,
  'color-converter': ColorConverter,
  'hash-generator': HashGenerator,
  'time-converter': TimestampConverter,
  'unit-converter': UnitConverter,
  'markdown-preview': MarkdownEditor,
};

const ToolComponent = toolComponentMap[slug];
const recentMeta = JSON.stringify({
  slug: tool.slug,
  name: name,
  icon: tool.icon,
  iconPath: tool.iconPath || '',
  type: tool.type,
  url: tool.url || '',
});
---

<BaseLayout
  lang={lang}
  pathname={pathname}
  title={name}
  description={desc}
>
  <div class="page" dir={dir}>
    <meta name="tool-meta" content={recentMeta} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t['nav.home'], item: new URL(`/${lang}/`, Astro.site).href },
        { '@type': 'ListItem', position: 2, name: t['nav.tools'], item: new URL(`/${lang}/tools`, Astro.site).href },
        { '@type': 'ListItem', position: 3, name: name },
      ],
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: name,
      applicationCategory: 'UtilityApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description: desc,
      ...(tool.type === 'builtin' ? { browserRequirements: 'Requires JavaScript' } : {}),
    })} />
    <div class="container">
      <nav class="breadcrumb">
        <a href={`/${lang}/`}>{t['nav.home']}</a>
        <span class="breadcrumb__sep">/</span>
        <a href={`/${lang}/tools`}>{t['nav.tools']}</a>
        <span class="breadcrumb__sep">/</span>
        <span>{name}</span>
      </nav>

      <article class="tool-detail">
        <header class="tool-detail__header">
          <div class="tool-detail__icon-wrap">
            {tool.iconPath ? (
              <img
                src={tool.iconPath}
                alt=""
                class="tool-detail__icon-img"
                loading="eager"
                decoding="async"
              />
            ) : (
              <span class="tool-detail__icon">{tool.icon}</span>
            )}
          </div>
          <div class="tool-detail__header-text">
            <div class="tool-detail__meta">
              <span class={`tool-detail__badge tool-detail__badge--${tool.type}`}>
                {tool.type === 'builtin' ? t['tools.type.builtin'] : t['tools.type.external']}
              </span>
              {ToolComponent && <span class="tool-detail__badge tool-detail__badge--live">Live</span>}
            </div>
            <h1 class="tool-detail__title">{name}</h1>
            <p class="tool-detail__desc">{desc}</p>
          </div>
        </header>

        <div class="tool-detail__content">
          <div class="tool-detail__main">
            {/* ═══ LIVE TOOL WORKSPACE ═══ */}
            {ToolComponent && tool.type === 'builtin' ? (
              <section class="tool-detail__section" id="tool-workspace">
                <ToolComponent lang={lang} />
              </section>
            ) : tool.type === 'builtin' ? (
              <div class="tool-detail__coming-soon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                </svg>
                <p>{t['tools.builtinComingSoon']}</p>
              </div>
            ) : null}

            <section class="tool-detail__section tool-detail__section--after-tool">
              <h2 class="tool-detail__section-title">{t['tools.about']}</h2>
              <div class="tool-detail__info-box">
                <p class="tool-detail__text">{longDesc}</p>
              </div>
            </section>

            {howToUse && (
              <section class="tool-detail__section">
                <h2 class="tool-detail__section-title">{t['tools.howToUse']}</h2>
                <div class="tool-detail__howWork-box">
                  <p class="tool-detail__text">{howToUse}</p>
                </div>
              </section>
            )}

            <section class="tool-detail__section">
              <h3 class="tool-detail__tags-title">{t['tools.tags']}</h3>
              <div class="tool-detail__tags">
                {tags.map(tag => (
                  <span class="tool-detail__tag"><span aria-hidden="true">#</span>{tag}</span>
                ))}
              </div>
            </section>
          </div>

          <aside class="tool-detail__sidebar">
            <div class="tool-detail__actions">
              {tool.type === 'external' && tool.url ? (
                <a
                  href={tool.url}
                  class="btn btn-primary btn-lg"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {t['tools.visit']}
                  <img class="tool-detail__click-icon" src="/general-icons/click/click-white.svg" alt="" aria-hidden="true" />
                </a>
              ) : tool.type === 'builtin' && ToolComponent ? (
                <a href="#tool-workspace" class="btn btn-primary btn-lg">
                  {t['tools.useNow']}
                  <img class="tool-detail__click-icon" src="/general-icons/click/click-white.svg" alt="" aria-hidden="true" />
                </a>
              ) : null}
              <a href={`/${lang}/tools`} class="btn btn-ghost tool-detail__back-action" aria-label={t['tools.backToTools']}>
                <img src="/general-icons/arrow/arrow-blue.svg" alt="" aria-hidden="true" />
              </a>
            </div>
          </aside>
        </div>
      </article>

      {relatedTools.length > 0 && (
        <section class="section related-section">
          <h2 class="section-header__title">{t['tools.relatedTools']}</h2>
          <div class="tools-grid" style="margin-top: var(--space-8);">
            {relatedTools.map(rt => (
              <ToolCard tool={rt} lang={lang} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  (function() {
    const STORAGE_KEY = 'belboore-recent-tools';
    const MAX = 8;
    try {
      const meta = document.querySelector('meta[name="tool-meta"]');
      if (!meta) return;
      const toolData = JSON.parse(meta.getAttribute('content') || '{}');
      if (!toolData.slug) return;

      let recent = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      recent = recent.filter((t: any) => t.slug !== toolData.slug);
      recent.unshift(toolData);
      if (recent.length > MAX) recent = recent.slice(0, MAX);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(recent));
    } catch {}
  })();
</script>

<style>
  .page {
    padding-block: var(--space-12);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-tertiary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--text-link);
  }

  .breadcrumb__sep {
    color: var(--border-strong);
  }

  .tool-detail__header {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    margin-bottom: var(--space-10);
  }

  .tool-detail__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: var(--radius-lg);
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .tool-detail__icon {
    font-size: 2rem;
    line-height: 1;
  }

  .tool-detail__icon-img {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  .tool-detail__header-text {
    flex: 1;
  }

  .tool-detail__meta {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .tool-detail__badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tool-detail__badge--builtin {
    background: var(--color-tech-blue-subtle);
    color: var(--color-tech-blue);
  }

  .tool-detail__badge--external {
    background: var(--color-electric-cyan-subtle);
    color: var(--color-electric-cyan);
  }

  .tool-detail__badge--live {
    background: var(--color-success-subtle);
    color: var(--color-success);
  }

  .tool-detail__title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    margin-bottom: var(--space-3);
  }

  .tool-detail__desc {
    font-size: var(--text-lg);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    max-width: 640px;
  }

  .tool-detail__content {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  .tool-detail__section {
    margin-bottom: var(--space-8);
  }

  .tool-detail__section--after-tool {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  .tool-detail__section-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .tool-detail__text {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .tool-detail__info-box {
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-inline-start: 3px solid var(--color-tech-blue);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
  }
  .tool-detail__howWork-box {
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-inline-start: 3px solid #8b5cf6;
    border-radius: var(--radius-sm);
    padding: var(--space-6);
  }

  .tool-detail__coming-soon {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    background: var(--color-electric-cyan-subtle);
    border: 1px solid rgba(0, 212, 255, 0.15);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .tool-detail__coming-soon p {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-electric-cyan);
  }

  .tool-detail__tags-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-5);
  }

  .tool-detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tool-detail__tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-tech-blue);
    background: var(--color-tech-blue-subtle);
    border-radius: var(--radius-full);
  }

  .tool-detail__sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
  }

  .tool-detail__actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--surface-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .tool-detail__actions .btn {
    flex: 1 1 0;
    justify-content: center;
  }

  .tool-detail__click-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .tool-detail__actions .tool-detail__back-action {
    flex: 0 0 auto;
    width: 48px;
    padding-inline: var(--space-3);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(190, 220, 240, 0.68)),
      var(--color-tech-blue-subtle);
    border-color: rgba(0, 82, 255, 0.1);
  }

  .tool-detail__back-action img {
    width: 16px;
    height: 16px;
    transform: rotate(180deg);
  }

  [dir="ltr"] .tool-detail__back-action img {
    transform: rotate(0deg);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .section-header__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .tool-detail__header {
      flex-direction: column;
    }

    .tool-detail__content {
      grid-template-columns: 1fr;
    }

    .tool-detail__sidebar {
      position: static;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }

    .tool-detail__title {
      font-size: var(--text-3xl);
    }
  }
</style>
